{
  "entities": {
    "Reading": {
      "title": "Tarot Reading",
      "description": "A saved tarot reading with its interpretation.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who performed the reading."
        },
        "question": {
          "type": "string",
          "description": "The question asked by the user."
        },
        "spreadType": {
          "type": "string",
          "enum": ["daily", "three-card", "celtic-cross"],
          "description": "The type of spread used."
        },
        "cards": {
          "type": "array",
          "description": "The list of cards drawn in the reading.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "position": { "type": "string" },
              "isReversed": { "type": "boolean" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "interpretation": {
          "type": "string",
          "description": "The AI-generated interpretation of the reading."
        },
        "timestamp": {
          "type": "number",
          "description": "The time the reading was saved."
        }
      },
      "required": ["userId", "spreadType", "cards", "interpretation", "timestamp"]
    },
    "User": {
      "title": "User Profile",
      "description": "Basic user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profile data."
    },
    "/readings/{readingId}": {
      "schema": "Reading",
      "description": "Saved tarot readings."
    }
  }
}
